<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EasyResult | Student Management System</title>

  <!-- CDN deps -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ── Base ── */
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; margin: 0; }

    /* ── Glass ── */
    .glass-card {
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    /* ── Scrollbar ── */
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #0f172a; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
    /* ── Animations ── */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }

    /* ── Modal scroll fix ── */
    /* overflow-hidden on modalContent was blocking scroll — removed via JS */
    #modalContent { overflow-y: auto; }

    /* ── Exam Config panel ── */
    .config-step {
      background: rgba(99,102,241,0.06);
      border: 1px solid rgba(99,102,241,0.18);
      border-radius: 1.25rem;
      padding: 1.25rem 1.5rem;
    }
    .config-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 999px;
      background: rgba(99,102,241,0.12);
      color: #818cf8;
      border: 1px solid rgba(99,102,241,0.25);
      margin-bottom: .75rem;
    }
    .pass-mark-preview {
      background: rgba(16,185,129,0.08);
      border: 1px solid rgba(16,185,129,0.2);
      border-radius: .75rem;
      padding: .65rem 1rem;
      font-size: 12px;
      color: #6ee7b7;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: .75rem;
    }

    /* ── Number input: hide spinners for cleaner look ── */
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { opacity: 0.4; }

    /* ── Select arrow colour ── */
    select option { background: #1e293b; }

    /* ── Error highlight ── */
    .input-error { border-color: #ef4444 !important; box-shadow: 0 0 0 2px rgba(239,68,68,0.3); }
  </style>
</head>

<body class="bg-slate-950 text-slate-200 overflow-hidden h-screen">
<div class="flex h-full w-full">

  <!-- ══════════════════════ SIDEBAR ══════════════════════ -->
  <aside class="w-20 md:w-64 bg-slate-900 border-r border-slate-800 flex flex-col transition-all duration-300 shrink-0">
    <div class="p-5 flex items-center gap-3">
      <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-indigo-600/30">
        <i data-lucide="award" class="text-white w-5 h-5"></i>
      </div>
      <h1 class="font-bold text-xl tracking-tight text-white hidden md:block">EasyResult</h1>
    </div>

    <nav class="flex-1 px-3 space-y-1 mt-4">
      <button onclick="switchTab('dashboard')" id="nav-dashboard"
        class="nav-btn w-full flex items-center gap-3 p-3 rounded-xl transition-all bg-indigo-600 text-white shadow-lg shadow-indigo-600/20">
        <i data-lucide="layout-dashboard" class="w-5 h-5 shrink-0"></i>
        <span class="font-medium hidden md:block">Dashboard</span>
      </button>
      <button onclick="switchTab('students')" id="nav-students"
        class="nav-btn w-full flex items-center gap-3 p-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400">
        <i data-lucide="users" class="w-5 h-5 shrink-0"></i>
        <span class="font-medium hidden md:block">Students</span>
      </button>

      <div class="pt-4 border-t border-slate-800 mt-4">
        <p class="text-[10px] font-bold text-slate-500 uppercase px-1 mb-2 hidden md:block">Data Ops</p>
        <button onclick="exportToExcel()"
          class="w-full flex items-center gap-3 p-3 rounded-xl text-slate-400 hover:bg-slate-800 transition-all">
          <i data-lucide="download" class="w-5 h-5 shrink-0"></i>
          <span class="font-medium hidden md:block">Export Data</span>
        </button>
      </div>
    </nav>
  </aside>

  <!-- ══════════════════════ MAIN ══════════════════════ -->
  <main class="flex-1 overflow-y-auto custom-scrollbar p-4 md:p-8 min-w-0">

    <!-- Header -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h2 id="page-title" class="text-3xl font-extrabold text-white">Academic Insights</h2>
        <p class="text-slate-400 text-sm mt-1">Real-time performance analytics and records</p>
      </div>
      <button onclick="openModal()"
        class="bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white px-6 py-3 rounded-xl flex items-center justify-center gap-2 transition-all shadow-xl shadow-indigo-600/20 group shrink-0">
        <i data-lucide="plus" class="w-4 h-4 group-hover:rotate-90 transition-transform duration-200"></i>
        <span class="font-semibold">Add Student</span>
      </button>
    </header>

    <!-- ── DASHBOARD VIEW ── -->
    <div id="view-dashboard" class="space-y-8 animate-fade-in">

      <!-- Stat cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-indigo-600/10 border border-indigo-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
          <div>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Total Records</p>
            <h4 id="stat-total" class="text-3xl font-black text-white">0</h4>
          </div>
          <i data-lucide="users" class="text-indigo-400 opacity-40 w-8 h-8"></i>
        </div>
        <div class="bg-emerald-600/10 border border-emerald-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
          <div>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Pass Rate</p>
            <h4 id="stat-pass" class="text-3xl font-black text-white">0%</h4>
          </div>
          <i data-lucide="check-circle" class="text-emerald-400 opacity-40 w-8 h-8"></i>
        </div>
        <div class="bg-amber-600/10 border border-amber-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
          <div>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Active ATKT</p>
            <h4 id="stat-atkt" class="text-3xl font-black text-white">0</h4>
          </div>
          <i data-lucide="trending-up" class="text-amber-400 opacity-40 w-8 h-8"></i>
        </div>
        <div class="bg-rose-600/10 border border-rose-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
          <div>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Failures</p>
            <h4 id="stat-fail" class="text-3xl font-black text-white">0</h4>
          </div>
          <i data-lucide="alert-circle" class="text-rose-400 opacity-40 w-8 h-8"></i>
        </div>
      </div>

      <!-- Charts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="glass-card border border-slate-800 p-6 rounded-3xl">
          <h3 class="text-base font-bold mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-indigo-500 inline-block"></span> Outcome Distribution
          </h3>
          <!-- FIX: fixed height so chart renders correctly -->
          <div style="height:260px; display:flex; align-items:center; justify-content:center;">
            <canvas id="pieChart"></canvas>
          </div>
        </div>
        <div class="glass-card border border-slate-800 p-6 rounded-3xl">
          <h3 class="text-base font-bold mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-indigo-500 inline-block"></span> Subject Averages
          </h3>
          <div style="height:220px; position:relative;">
            <canvas id="barChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Empty state for dashboard -->
      <div id="dashboard-empty" class="hidden text-center py-16">
        <i data-lucide="bar-chart-2" class="w-16 h-16 mx-auto text-slate-700 mb-4"></i>
        <p class="text-slate-500 text-lg font-semibold">No student data yet</p>
        <p class="text-slate-600 text-sm mt-1">Add your first student to see analytics</p>
      </div>
    </div>

    <!-- ── STUDENTS VIEW ── -->
    <div id="view-students" class="hidden animate-fade-in">
      <div class="glass-card border border-slate-800 rounded-3xl overflow-hidden shadow-2xl">

        <!-- Toolbar -->
        <div class="p-5 border-b border-slate-800 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div class="relative flex-1 max-w-sm">
            <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 w-4 h-4 pointer-events-none"></i>
            <input type="text" id="searchInput" oninput="renderTable()" placeholder="Search students…"
              class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl py-3 pl-11 pr-4 text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 transition-all text-sm">
          </div>
          <div class="flex bg-slate-800/80 p-1.5 rounded-2xl border border-slate-700 gap-1 shrink-0">
            <button onclick="setFilter('All')"  class="filter-btn px-4 py-2 rounded-xl text-xs font-bold bg-indigo-600 text-white">All</button>
            <button onclick="setFilter('Pass')" class="filter-btn px-4 py-2 rounded-xl text-xs font-bold text-slate-400 hover:text-white transition-colors">Pass</button>
            <button onclick="setFilter('Fail')" class="filter-btn px-4 py-2 rounded-xl text-xs font-bold text-slate-400 hover:text-white transition-colors">Fail</button>
            <button onclick="setFilter('ATKT')" class="filter-btn px-4 py-2 rounded-xl text-xs font-bold text-slate-400 hover:text-white transition-colors">ATKT</button>
          </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-slate-800/30 text-slate-500 text-[10px] uppercase font-bold tracking-widest">
                <th class="px-8 py-5">Full Name</th>
                <th class="px-4 py-5">Subjects</th>
                <th class="px-6 py-5">Status</th>
                <th class="px-6 py-5">Summary</th>
                <th class="px-8 py-5 text-right">Actions</th>
              </tr>
            </thead>
            <tbody id="studentTableBody" class="divide-y divide-slate-800/50"></tbody>
          </table>
        </div>
      </div>
    </div>

  </main>
</div>

<!-- ══════════════════════ MODAL ══════════════════════ -->
<div id="modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  style="background:rgba(0,0,0,0.8); backdrop-filter:blur(6px);">

  <div id="modalContent"
    class="bg-slate-900 border border-slate-800 w-full max-w-2xl rounded-[2rem] shadow-2xl flex flex-col transition-transform duration-300 scale-95"
    style="max-height:92vh;">

    <!-- Modal header — sticky -->
    <div class="p-7 border-b border-slate-800 flex justify-between items-center bg-slate-900 rounded-t-[2rem] shrink-0">
      <div>
        <h3 id="modal-title" class="text-2xl font-black text-white">Enroll Student</h3>
        <p class="text-sm text-slate-500 mt-0.5">Provide details and subject marks</p>
      </div>
      <button onclick="closeModal()"
        class="text-slate-500 hover:text-white p-2 rounded-2xl hover:bg-slate-800 transition-colors">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>

    <!-- Modal body — scrollable -->
    <form id="studentForm" onsubmit="saveStudent(event)" novalidate class="overflow-y-auto custom-scrollbar p-7 flex flex-col gap-6">
      <input type="hidden" id="editId" />

      <!-- Name row -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div class="space-y-1.5">
          <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">First Name *</label>
          <input type="text" id="fname" autocomplete="given-name"
            class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm" />
        </div>
        <div class="space-y-1.5">
          <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Middle Name</label>
          <input type="text" id="mname" autocomplete="additional-name"
            class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm" />
        </div>
        <div class="space-y-1.5">
          <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Last Name *</label>
          <input type="text" id="lname" autocomplete="family-name"
            class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm" />
        </div>
      </div>

      <!-- Exam Configuration -->
      <div class="config-step">
        <div class="config-badge">
          <i data-lucide="settings" class="w-3 h-3"></i> Exam Configuration
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Total Marks -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Total Marks Per Subject</label>
            <select id="totalMarksSelect" onchange="handleTotalMarksChange()"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm cursor-pointer">
              <option value="50">50</option>
              <option value="80">80</option>
              <option value="100" selected>100</option>
              <option value="150">150</option>
              <option value="200">200</option>
              <option value="custom">Custom…</option>
            </select>
            <input type="number" id="totalMarksCustom" placeholder="Enter custom value (e.g. 75)" min="1" max="9999" step="1"
              class="hidden w-full bg-slate-800 border border-indigo-500/40 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm mt-2" />
          </div>
          <!-- Passing % -->
          <div class="space-y-1.5">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Passing Percentage</label>
            <select id="passPercSelect" onchange="handlePassPercChange()"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm cursor-pointer">
              <option value="35" selected>35%</option>
              <option value="40">40%</option>
              <option value="50">50%</option>
              <option value="custom">Custom…</option>
            </select>
            <input type="number" id="passPercCustom" placeholder="e.g. 45 (enter number only)" min="1" max="100" step="0.1"
              class="hidden w-full bg-slate-800 border border-indigo-500/40 rounded-2xl px-4 py-3.5 text-white focus:ring-2 focus:ring-indigo-600 outline-none transition-all text-sm mt-2" />
          </div>
        </div>
        <!-- Live preview -->
        <div class="pass-mark-preview" id="passMarkPreview">
          <i data-lucide="shield-check" class="w-4 h-4 shrink-0"></i>
          <span id="passMarkText">Pass mark per subject: <strong>35</strong> out of <strong>100</strong> (35%)</span>
        </div>
      </div>

      <!-- Marks divider -->
      <div class="flex items-center gap-3">
        <div class="h-px bg-slate-800 flex-1"></div>
        <span class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] whitespace-nowrap">Marks Inventory</span>
        <div class="h-px bg-slate-800 flex-1"></div>
      </div>

      <!-- Subject inputs — built dynamically -->
      <div id="subjectInputsGrid" class="grid grid-cols-2 sm:grid-cols-4 gap-4"></div>

      <!-- Form error message -->
      <div id="formError" class="hidden bg-rose-500/10 border border-rose-500/20 rounded-2xl px-4 py-3 text-rose-400 text-sm flex items-center gap-2">
        <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i>
        <span id="formErrorText"></span>
      </div>

      <!-- Actions -->
      <div class="flex justify-end gap-3 pt-2 border-t border-slate-800">
        <button type="button" onclick="closeModal()"
          class="px-7 py-3.5 text-slate-400 hover:text-white font-semibold transition-colors rounded-2xl hover:bg-slate-800">Discard</button>
        <button type="submit"
          class="bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white px-9 py-3.5 rounded-2xl font-bold shadow-xl shadow-indigo-600/20 transition-all">
          Confirm Enrollment
        </button>
      </div>
    </form>
  </div>
</div>

<!-- ══════════════════════ TOAST ══════════════════════ -->
<div id="toast"
  class="fixed bottom-8 right-8 px-5 py-3.5 rounded-2xl border bg-slate-900 border-slate-700 text-white shadow-2xl translate-x-[200%] transition-transform duration-500 z-[200] flex items-center gap-3 max-w-xs">
  <i id="toast-icon" data-lucide="check-circle" class="w-5 h-5 shrink-0"></i>
  <span id="toast-msg" class="text-sm font-medium">Success</span>
</div>

<!-- ══════════════════════ SCRIPT ══════════════════════ -->
<script>
"use strict";

/* ─────────────────────────── STATE ─────────────────────────── */
let students      = [];
let currentFilter = 'All';
let charts        = { pie: null, bar: null };
let toastTimer    = null;

// Load from localStorage safely
try {
  const raw = localStorage.getItem('rp_students');
  if (raw) students = JSON.parse(raw) || [];
} catch (e) { students = []; }

/* ─────────────── SUBJECT DEFINITION (single source of truth) ─────────────── */
const SUBJECTS = [
  { id: 's_english', label: 'English'        },
  { id: 's_maths',   label: 'Maths'          },
  { id: 's_marathi', label: 'Marathi'        },
  { id: 's_hindi',   label: 'Hindi'          },
  { id: 's_science', label: 'Science'        },
  { id: 's_history', label: 'History/Civics' },
  { id: 's_geo',     label: 'Geography'      },
];

/* ─────────────── INIT ─────────────── */
document.addEventListener('DOMContentLoaded', () => {
  lucide.createIcons();
  buildSubjectInputs();
  refreshPassMarkPreview();
  updateDashboard();
  renderTable();
});

/* ─────────────────────────── NAVIGATION ─────────────────────────── */
function switchTab(tab) {
  const isDash = tab === 'dashboard';
  document.getElementById('view-dashboard').classList.toggle('hidden', !isDash);
  document.getElementById('view-students').classList.toggle('hidden', isDash);
  document.getElementById('page-title').textContent = isDash ? 'Academic Insights' : 'Student Database';

  ['dashboard', 'students'].forEach(t => {
    const btn = document.getElementById('nav-' + t);
    const active = t === tab;
    btn.classList.toggle('bg-indigo-600', active);
    btn.classList.toggle('shadow-lg', active);
    btn.classList.toggle('shadow-indigo-600/20', active);
    btn.classList.toggle('text-white', active);
    btn.classList.toggle('text-slate-400', !active);
    btn.classList.toggle('hover:bg-slate-800', !active);
  });

  if (isDash) updateDashboard();
}

/* ─────────────────────────── EXAM CONFIG ─────────────────────────── */

/** Get total marks per subject currently selected in form */
function getConfiguredTotalMarks() {
  const sel = document.getElementById('totalMarksSelect');
  if (!sel) return 100;
  if (sel.value === 'custom') {
    const v = parseFloat(document.getElementById('totalMarksCustom').value);
    return (!isNaN(v) && v > 0) ? v : 0;
  }
  return parseFloat(sel.value) || 100;
}

/** Get passing percentage currently selected in form */
function getConfiguredPassPerc() {
  const sel = document.getElementById('passPercSelect');
  if (!sel) return 35;
  if (sel.value === 'custom') {
    const v = parseFloat(document.getElementById('passPercCustom').value);
    return (!isNaN(v) && v > 0 && v <= 100) ? v : 0;
  }
  return parseFloat(sel.value) || 35;
}

/** Calculate the raw pass mark */
function calcPassMark(totalMarks, passPerc) {
  return (totalMarks * passPerc) / 100;
}

/** Refresh the live preview badge and input max attributes */
function refreshPassMarkPreview() {
  const tm = getConfiguredTotalMarks();
  const pp = getConfiguredPassPerc();
  if (tm <= 0 || pp <= 0) {
    document.getElementById('passMarkText').innerHTML = 'Enter valid total marks and passing percentage';
    return;
  }
  const pm = calcPassMark(tm, pp);
  const pmDisplay = Number.isInteger(pm) ? pm : pm.toFixed(2);
  document.getElementById('passMarkText').innerHTML =
    `Pass mark per subject: <strong>${pmDisplay}</strong> out of <strong>${tm}</strong> (${pp}%)`;

  // Sync max attribute on all subject inputs
  document.querySelectorAll('#subjectInputsGrid input[type="number"]').forEach(inp => {
    inp.max = tm;
    inp.placeholder = `0 – ${tm}`;
  });
}

function handleTotalMarksChange() {
  const sel  = document.getElementById('totalMarksSelect');
  const cust = document.getElementById('totalMarksCustom');
  if (sel.value === 'custom') {
    cust.classList.remove('hidden');
    // Attach once — use oninput attribute on element, not addEventListener to avoid stacking
  } else {
    cust.classList.add('hidden');
    cust.value = '';
  }
  refreshPassMarkPreview();
  // Rebuild inputs to sync max values
  buildSubjectInputs(collectCurrentMarks());
}

function handlePassPercChange() {
  const sel  = document.getElementById('passPercSelect');
  const cust = document.getElementById('passPercCustom');
  if (sel.value === 'custom') {
    cust.classList.remove('hidden');
  } else {
    cust.classList.add('hidden');
    cust.value = '';
  }
  refreshPassMarkPreview();
}

/** Collect whatever marks are currently in the inputs (for rebuild on config change) */
function collectCurrentMarks() {
  const m = {};
  SUBJECTS.forEach(sub => {
    const inp = document.getElementById(sub.id);
    if (inp && inp.value !== '') m[sub.id] = parseFloat(inp.value);
  });
  return m;
}

/* ─────────────────────────── SUBJECT INPUT GRID ─────────────────────────── */
function buildSubjectInputs(existingMarks = {}) {
  const tm   = getConfiguredTotalMarks() || 100;
  const grid = document.getElementById('subjectInputsGrid');
  if (!grid) return;

  grid.innerHTML = SUBJECTS.map(sub => {
    const val = existingMarks[sub.id] !== undefined ? existingMarks[sub.id] : '';
    return `
      <div class="space-y-2 text-center">
        <label class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">${sub.label}</label>
        <input
          type="number" id="${sub.id}"
          min="0" max="${tm}" step="1"
          placeholder="0 – ${tm}"
          value="${val}"
          oninput="onMarkInput(this)"
          class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-2 py-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold text-sm transition-all" />
      </div>`;
  }).join('');

  lucide.createIcons();
}

function onMarkInput(inp) {
  inp.classList.remove('input-error');
  hideFormError();
  const tm = getConfiguredTotalMarks();
  if (inp.value === '') return;
  const v = parseFloat(inp.value);
  if (isNaN(v) || v < 0) {
    inp.value = 0;
    return;
  }
  if (v > tm) {
    inp.value = tm;
    showToast(`Max marks per subject is ${tm}`, 'alert-circle', 'amber');
  }
}

/* ─────────────────────────── CALCULATION LOGIC ─────────────────────────── */
/**
 * @param {Object} marksMap         { subjectId: obtainedMark }
 * @param {number} totalMarksPerSub
 * @param {number} passingPerc      0-100
 * @returns {{ total, maxMarks, percentage, status, failCount, passMark }}
 */
function calculateResult(marksMap, totalMarksPerSub, passingPerc) {
  const values      = Object.values(marksMap);
  const numSubjects = values.length;
  const passMark    = calcPassMark(totalMarksPerSub, passingPerc);
  const failCount   = values.filter(v => v < passMark).length;
  const total       = values.reduce((a, b) => a + b, 0);
  const maxMarks    = numSubjects * totalMarksPerSub;
  const percentage  = maxMarks > 0 ? ((total / maxMarks) * 100).toFixed(2) : '0.00';

  let status = 'Pass';
  if (failCount >= 3)      status = 'Fail';
  else if (failCount >= 1) status = 'ATKT';

  return { total, maxMarks, percentage, status, failCount, passMark };
}

/* ─────────────────────────── CRUD ─────────────────────────── */
function saveStudent(e) {
  e.preventDefault();
  clearAllInputErrors();
  hideFormError();

  // ── Validate name
  const fname = document.getElementById('fname').value.trim();
  const mname = document.getElementById('mname').value.trim();
  const lname = document.getElementById('lname').value.trim();

  if (!fname) {
    markInputError('fname', 'First name is required');
    return;
  }
  if (!lname) {
    markInputError('lname', 'Last name is required');
    return;
  }

  // ── Validate config
  const totalMarksPerSubject = getConfiguredTotalMarks();
  const passingPercentage    = getConfiguredPassPerc();

  if (!totalMarksPerSubject || totalMarksPerSubject <= 0) {
    showFormError('Please enter a valid total marks value (must be > 0)');
    return;
  }
  if (!passingPercentage || passingPercentage <= 0 || passingPercentage > 100) {
    showFormError('Passing percentage must be between 1 and 100');
    return;
  }

  // ── Collect & validate marks
  const marks = {};
  let hasError = false;

  SUBJECTS.forEach(sub => {
    const inp = document.getElementById(sub.id);
    const raw = inp.value.trim();
    if (raw === '') {
      markInputError(sub.id, `${sub.label} is required`);
      hasError = true;
      return;
    }
    const v = parseFloat(raw);
    if (isNaN(v) || v < 0) {
      markInputError(sub.id, `${sub.label}: invalid value`);
      hasError = true;
      return;
    }
    if (v > totalMarksPerSubject) {
      markInputError(sub.id, `${sub.label}: cannot exceed ${totalMarksPerSubject}`);
      hasError = true;
      return;
    }
    marks[sub.id] = v;
  });

  if (hasError) {
    showFormError('Please fix the highlighted fields above');
    return;
  }

  const result  = calculateResult(marks, totalMarksPerSubject, passingPercentage);
  const editId  = document.getElementById('editId').value;

  const student = {
    id:                   editId || String(Date.now()),
    firstName:            fname,
    middleName:           mname,
    lastName:             lname,
    fullName:             [fname, mname, lname].filter(Boolean).join(' '),
    marks,
    totalMarksPerSubject,
    passingPercentage,
    ...result
  };

  if (editId) {
    const idx = students.findIndex(s => s.id === editId);
    if (idx !== -1) students[idx] = student;
    showToast('Record updated', 'check-circle', 'emerald');
  } else {
    students.push(student);
    showToast('Student enrolled', 'check-circle', 'indigo');
  }

  saveToStorage();
  closeModal();
  renderTable();
  updateDashboard();
}

function deleteStudent(id) {
  if (!confirm('Delete this student record permanently?')) return;
  students = students.filter(s => s.id !== id);
  saveToStorage();
  renderTable();
  updateDashboard();
  showToast('Record deleted', 'trash-2', 'rose');
}

function editStudent(id) {
  const s = students.find(x => x.id === id);
  if (!s) return;

  document.getElementById('editId').value = s.id;
  document.getElementById('fname').value  = s.firstName  || '';
  document.getElementById('mname').value  = s.middleName || '';
  document.getElementById('lname').value  = s.lastName   || '';

  // Restore Total Marks
  const tmSel  = document.getElementById('totalMarksSelect');
  const tmStr  = String(s.totalMarksPerSubject);
  const tmOpts = [...tmSel.options].map(o => o.value);
  if (tmOpts.includes(tmStr)) {
    tmSel.value = tmStr;
    document.getElementById('totalMarksCustom').classList.add('hidden');
  } else {
    tmSel.value = 'custom';
    const c = document.getElementById('totalMarksCustom');
    c.classList.remove('hidden');
    c.value = s.totalMarksPerSubject;
  }

  // Restore Pass %
  const ppSel  = document.getElementById('passPercSelect');
  const ppStr  = String(s.passingPercentage);
  const ppOpts = [...ppSel.options].map(o => o.value);
  if (ppOpts.includes(ppStr)) {
    ppSel.value = ppStr;
    document.getElementById('passPercCustom').classList.add('hidden');
  } else {
    ppSel.value = 'custom';
    const c = document.getElementById('passPercCustom');
    c.classList.remove('hidden');
    c.value = s.passingPercentage;
  }

  refreshPassMarkPreview();
  buildSubjectInputs(s.marks);

  document.getElementById('modal-title').textContent = 'Edit Record';
  openModal();
}

