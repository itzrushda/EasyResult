/* ─────────────────────────── DASHBOARD ─────────────────────────── */
function updateDashboard() {
  const total  = students.length;
  const passed = students.filter(s => s.status === 'Pass').length;
  const failed = students.filter(s => s.status === 'Fail').length;
  const atkt   = students.filter(s => s.status === 'ATKT').length;

  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-pass').textContent  = total ? Math.round((passed / total) * 100) + '%' : '0%';
  document.getElementById('stat-atkt').textContent  = atkt;
  document.getElementById('stat-fail').textContent  = failed;

  // Show/hide empty state
  const emptyEl = document.getElementById('dashboard-empty');
  if (emptyEl) emptyEl.classList.toggle('hidden', total > 0);

  initCharts(passed, failed, atkt);
}

function initCharts(p, f, a) {
  ['pie','bar'].forEach(k => { if (charts[k]) { charts[k].destroy(); charts[k] = null; } });

  // ── Pie / Doughnut
  const ctxPie = document.getElementById('pieChart');
  if (ctxPie) {
    charts.pie = new Chart(ctxPie, {
      type: 'doughnut',
      data: {
        labels: ['Pass', 'Fail', 'ATKT'],
        datasets: [{
          data: [p, f, a],
          backgroundColor: ['#10b981', '#ef4444', '#f59e0b'],
          borderWidth: 0,
          hoverOffset: 12
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#94a3b8', padding: 16, font: { size: 12 } }
          }
        }
      }
    });
  }

  // ── Bar — dynamic subjects, dynamic averages
  const ctxBar = document.getElementById('barChart');
  if (!ctxBar) return;

  // Collect averages only for subjects that have data
  const totals = {}, counts = {};
  students.forEach(s => {
    SUBJECTS.forEach(sub => {
      if (s.marks[sub.id] !== undefined) {
        totals[sub.id] = (totals[sub.id] || 0) + s.marks[sub.id];
        counts[sub.id] = (counts[sub.id] || 0) + 1;
      }
    });
  });

  const presentSubs = SUBJECTS.filter(sub => counts[sub.id]);
  const barLabels   = presentSubs.map(sub => sub.label);
  const barData     = presentSubs.map(sub => (totals[sub.id] / counts[sub.id]).toFixed(1));

  charts.bar = new Chart(ctxBar, {
    type: 'bar',
    data: {
      labels: barLabels.length ? barLabels : ['No Data'],
      datasets: [{
        label: 'Average Score',
        data:  barData.length  ? barData  : [0],
        backgroundColor: '#6366f1',
        borderRadius: 8,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: {
          beginAtZero: true,
          grid:  { color: '#1e293b' },
          ticks: { color: '#64748b', font: { size: 11 } }
        },
        x: {
          grid:  { display: false },
          ticks: { color: '#64748b', font: { size: 11 } }
        }
      },
      plugins: { legend: { display: false } }
    }
  });
}

/* ─────────────────────────── EXPORT EXCEL ─────────────────────────── */
function exportToExcel() {
  if (!students.length) {
    showToast('No data to export', 'alert-circle', 'amber');
    return;
  }

  const data = students.map(s => {
    const row = {
      'Student Name':         s.fullName,
      'Total Marks/Subject':  s.totalMarksPerSubject,
      'Passing Percentage':   s.passingPercentage + '%',
      'Pass Mark':            Number.isInteger(s.passMark) ? s.passMark : parseFloat(s.passMark.toFixed(2)),
    };
    SUBJECTS.forEach(sub => {
      if (s.marks[sub.id] !== undefined) row[sub.label] = s.marks[sub.id];
    });
    row['Total Obtained'] = s.total;
    row['Max Marks']      = s.maxMarks;
    row['Percentage']     = s.percentage + '%';
    row['Result']         = s.status;
    return row;
  });

  try {
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Results');
    XLSX.writeFile(wb, 'Student_Results.xlsx');
    showToast('Excel exported successfully', 'download', 'emerald');
  } catch (err) {
    showToast('Export failed — try again', 'alert-circle', 'rose');
  }
}

/* ─────────────────────────── PDF REPORT ─────────────────────────── */
function downloadPDF(id) {
  const s = students.find(x => x.id === id);
  if (!s) return;

  try {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

    // Header bar
    doc.setFillColor(30, 41, 59);
    doc.rect(0, 0, 210, 38, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(18);
    doc.setFont('helvetica', 'bold');
    doc.text('ACADEMIC REPORT CARD', 105, 18, { align: 'center' });
    doc.setFontSize(10);
    doc.setFont('helvetica', 'normal');
    doc.text('EasyResult — Student Management System', 105, 28, { align: 'center' });

    // Student info
    doc.setTextColor(15, 23, 42);
    doc.setFontSize(12);
    doc.setFont('helvetica', 'bold');
    doc.text(s.fullName, 20, 52);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    doc.setTextColor(100, 116, 139);
    doc.text(`ID: ${s.id.slice(-8)}`, 20, 59);
    doc.text(`Generated: ${new Date().toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}`, 150, 59, { align: 'right' });

    // Config info box
    doc.setFillColor(241, 245, 249);
    doc.roundedRect(20, 64, 170, 24, 3, 3, 'F');
    doc.setTextColor(71, 85, 105);
    doc.setFontSize(9);
    const pm = s.passMark;
    const pmDisp = Number.isInteger(pm) ? pm : pm.toFixed(2);
    doc.text(`Total Marks Per Subject: ${s.totalMarksPerSubject}`, 27, 72);
    doc.text(`Passing Percentage: ${s.passingPercentage}%`, 27, 79);
    doc.text(`Required Pass Mark: ${pmDisp} / ${s.totalMarksPerSubject}`, 115, 72);
    doc.text(`Subjects Appeared: ${Object.keys(s.marks).length}`, 115, 79);

    // Marks table
    const tableRows = SUBJECTS
      .filter(sub => s.marks[sub.id] !== undefined)
      .map(sub => {
        const m    = s.marks[sub.id];
        const pct  = ((m / s.totalMarksPerSubject) * 100).toFixed(1);
        const res  = m >= s.passMark ? 'PASS' : 'FAIL';
        return [sub.label, `${m} / ${s.totalMarksPerSubject}`, `${pct}%`, res];
      });

    doc.autoTable({
      startY: 92,
      head:   [['Subject', 'Marks Obtained', 'Subject %', 'Status']],
      body:   tableRows,
      theme:  'striped',
      headStyles:    { fillColor: [99, 102, 241], textColor: 255, fontStyle: 'bold', fontSize: 10 },
      bodyStyles:    { fontSize: 10, textColor: [15, 23, 42] },
      alternateRowStyles: { fillColor: [248, 250, 252] },
      columnStyles: {
        0: { fontStyle: 'bold' },
        3: { fontStyle: 'bold', halign: 'center' }
      },
      didDrawCell(data) {
        if (data.section === 'body' && data.column.index === 3) {
          data.cell.styles.textColor = data.cell.raw === 'FAIL' ? [220, 38, 38] : [5, 150, 105];
        }
      }
    });

    // Summary section
    const fy = doc.lastAutoTable.finalY + 10;
    doc.setFillColor(248, 250, 252);
    doc.roundedRect(20, fy, 170, 32, 3, 3, 'F');

    doc.setFontSize(10);
    doc.setTextColor(71, 85, 105);
    doc.text('Total Marks Obtained:', 27, fy + 10);
    doc.text('Overall Percentage:', 27, fy + 18);
    doc.text('Subjects Failed:', 27, fy + 26);

    doc.setFont('helvetica', 'bold');
    doc.setTextColor(15, 23, 42);
    doc.text(`${s.total} / ${s.maxMarks}`, 95, fy + 10);
    doc.text(`${s.percentage}%`, 95, fy + 18);
    doc.text(`${s.failCount} of ${Object.keys(s.marks).length}`, 95, fy + 26);

    // Result badge
    const rc = s.status === 'Pass' ? [5, 150, 105] : s.status === 'Fail' ? [220, 38, 38] : [217, 119, 6];
    doc.setFillColor(...rc);
    doc.roundedRect(130, fy + 4, 55, 22, 4, 4, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(14);
    doc.text(s.status.toUpperCase(), 157.5, fy + 18, { align: 'center' });

    // Footer
    doc.setFontSize(8);
    doc.setTextColor(148, 163, 184);
    doc.setFont('helvetica', 'normal');
    doc.text('This is a system-generated report. For official use only.', 105, 285, { align: 'center' });

    doc.save(`${s.fullName.replace(/\s+/g, '_')}_Report.pdf`);
    showToast('PDF downloaded', 'file-text', 'indigo');
  } catch (err) {
    console.error('PDF error:', err);
    showToast('PDF generation failed', 'alert-circle', 'rose');
  }
}

/* ─────────────────────────── MODAL ─────────────────────────── */
function openModal() {
  const modal   = document.getElementById('modal');
  const content = document.getElementById('modalContent');
  modal.classList.remove('hidden');
  modal.classList.add('flex');
  // Slight delay so transition works
  requestAnimationFrame(() => {
    content.classList.remove('scale-95');
    content.classList.add('scale-100');
  });
  // Trap scroll
  document.body.style.overflow = 'hidden';
  // Focus first field
  setTimeout(() => document.getElementById('fname')?.focus(), 150);
}

function closeModal() {
  const modal   = document.getElementById('modal');
  const content = document.getElementById('modalContent');
  content.classList.remove('scale-100');
  content.classList.add('scale-95');
  setTimeout(() => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }, 200);
  document.body.style.overflow = '';

  // Reset form
  document.getElementById('studentForm').reset();
  document.getElementById('editId').value = '';
  document.getElementById('modal-title').textContent = 'Enroll Student';

  // Reset config
  document.getElementById('totalMarksSelect').value = '100';
  document.getElementById('totalMarksCustom').classList.add('hidden');
  document.getElementById('totalMarksCustom').value = '';
  document.getElementById('passPercSelect').value = '35';
  document.getElementById('passPercCustom').classList.add('hidden');
  document.getElementById('passPercCustom').value = '';

  clearAllInputErrors();
  hideFormError();
  refreshPassMarkPreview();
  buildSubjectInputs();
}

// Close modal when clicking backdrop
document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Close modal on Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && !document.getElementById('modal').classList.contains('hidden')) {
    closeModal();
  }
});

/* ─────────────────────────── FILTER ─────────────────────────── */
function setFilter(f) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(btn => {
    const isActive = btn.textContent.trim() === f;
    btn.classList.toggle('bg-indigo-600', isActive);
    btn.classList.toggle('text-white',    isActive);
    btn.classList.toggle('text-slate-400', !isActive);
  });
  renderTable();
}

/* ─────────────────────────── TOAST ─────────────────────────── */
function showToast(msg, iconName, color) {
  if (toastTimer) clearTimeout(toastTimer);
  const toast    = document.getElementById('toast');
  const iconEl   = document.getElementById('toast-icon');
  const msgEl    = document.getElementById('toast-msg');

  msgEl.textContent = msg;
  // Set color class — use inline style to avoid Tailwind purge
  const colourMap = {
    indigo:  ['#6366f1', 'rgba(99,102,241,0.2)'],
    emerald: ['#10b981', 'rgba(16,185,129,0.2)'],
    rose:    ['#f43f5e', 'rgba(244,63,94,0.2)'],
    amber:   ['#f59e0b', 'rgba(245,158,11,0.2)'],
  };
  const [fg, bg] = colourMap[color] || colourMap.indigo;
  toast.style.color       = fg;
  toast.style.borderColor = bg;
  iconEl.style.color      = fg;

  // Swap SVG icon inline (avoid lucide re-init flash)
  const icons = {
    'check-circle': `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    'alert-circle': `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    'trash-2':      `<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>`,
    'download':     `<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>`,
    'file-text':    `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  };
  iconEl.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">${icons[iconName] || icons['check-circle']}</svg>`;

  toast.classList.remove('translate-x-[200%]');
  toastTimer = setTimeout(() => toast.classList.add('translate-x-[200%]'), 3000);
}

/* ─────────────────────────── VALIDATION HELPERS ─────────────────────────── */
function markInputError(id, msg) {
  const inp = document.getElementById(id);
  if (inp) inp.classList.add('input-error');
}

function clearAllInputErrors() {
  document.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));
}

function showFormError(msg) {
  const el = document.getElementById('formError');
  document.getElementById('formErrorText').textContent = msg;
  el.classList.remove('hidden');
  el.classList.add('flex');
  lucide.createIcons({ nodes: [el] });
}

function hideFormError() {
  const el = document.getElementById('formError');
  el.classList.add('hidden');
  el.classList.remove('flex');
}

/* ─────────────────────────── STORAGE ─────────────────────────── */
function saveToStorage() {
  try {
    localStorage.setItem('rp_students', JSON.stringify(students));
  } catch (e) {
    showToast('Storage full — export data before adding more', 'alert-circle', 'rose');
  }
}
</script>
</body>
</html>
