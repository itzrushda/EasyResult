<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ResultPro | Student Management System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }

    .glass-card {
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(12px);
    }

    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: #0f172a;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #334155;
      border-radius: 10px;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeIn 0.4s ease-out forwards;
    }
  </style>
</head>

<body class="bg-slate-950 text-slate-200 overflow-hidden h-screen">

  <div class="flex h-full w-full">
    <!-- Sidebar -->
    <aside class="w-20 md:w-64 bg-slate-900 border-r border-slate-800 flex flex-col transition-all duration-300">
      <div class="p-6 flex items-center gap-3">
        <div
          class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-indigo-600/30">
          <i data-lucide="award" class="text-white"></i>
        </div>
        <h1 class="font-bold text-xl tracking-tight text-white hidden md:block">EasyResult</h1>
      </div>

      <nav class="flex-1 px-3 space-y-2 mt-6">
        <button onclick="switchTab('dashboard')" id="nav-dashboard"
          class="w-full flex items-center gap-3 p-3 rounded-xl transition-all bg-indigo-600 text-white shadow-lg">
          <i data-lucide="layout-dashboard" size="20"></i>
          <span class="font-medium hidden md:block">Dashboard</span>
        </button>
        <button onclick="switchTab('students')" id="nav-students"
          class="w-full flex items-center gap-3 p-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400">
          <i data-lucide="users" size="20"></i>
          <span class="font-medium hidden md:block">Students</span>
        </button>

        <div class="pt-4 border-t border-slate-800 mt-4 mx-2">
          <p class="text-[10px] font-bold text-slate-500 uppercase px-2 mb-2 hidden md:block">Data Ops</p>
          <!-- <button onclick="document.getElementById('importFile').click()"
            class="w-full flex items-center gap-3 p-3 rounded-xl text-slate-400 hover:bg-slate-800 transition-all">
            <i data-lucide="upload" size="20"></i>
            <span class="font-medium hidden md:block">Import Excel</span>
          </button>
          <input type="file" id="importFile" class="hidden" accept=".xlsx,.xls,.csv" onchange="importFromExcel(event)"> -->

          <button onclick="exportToExcel()"
            class="w-full flex items-center gap-3 p-3 rounded-xl text-slate-400 hover:bg-slate-800 transition-all">
            <i data-lucide="download" size="20"></i>
            <span class="font-medium hidden md:block">Export Data</span>
          </button>
        </div>
      </nav>
    </aside>

    <main class="flex-1 overflow-y-auto custom-scrollbar p-4 md:p-8">
      <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
          <h2 id="page-title" class="text-3xl font-extrabold text-white">Academic Insights</h2>
          <p class="text-slate-400">Real-time performance analytics and records</p>
        </div>
        <button onclick="openModal()"
          class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl flex items-center justify-center gap-2 transition-all shadow-xl shadow-indigo-600/20 group">
          <i data-lucide="plus" class="group-hover:rotate-90 transition-transform"></i>
          <span>Add Student</span>
        </button>
      </header>

      <!-- Dashboard View -->
      <div id="view-dashboard" class="space-y-8 animate-fade-in">
        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <div
            class="bg-indigo-600/10 border border-indigo-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
            <div>
              <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Total Records</p>
              <h4 id="stat-total" class="text-3xl font-black text-white">0</h4>
            </div>
            <i data-lucide="users" class="text-indigo-400 opacity-40" size="32"></i>
          </div>
          <div
            class="bg-emerald-600/10 border border-emerald-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
            <div>
              <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Pass rate</p>
              <h4 id="stat-pass" class="text-3xl font-black text-white">0%</h4>
            </div>
            <i data-lucide="check-circle" class="text-emerald-400 opacity-40" size="32"></i>
          </div>
          <div
            class="bg-amber-600/10 border border-amber-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
            <div>
              <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Active ATKT</p>
              <h4 id="stat-atkt" class="text-3xl font-black text-white">0</h4>
            </div>
            <i data-lucide="trending-up" class="text-amber-400 opacity-40" size="32"></i>
          </div>
          <div
            class="bg-rose-600/10 border border-rose-500/20 p-5 rounded-3xl flex items-center justify-between shadow-lg">
            <div>
              <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">Failures</p>
              <h4 id="stat-fail" class="text-3xl font-black text-white">0</h4>
            </div>
            <i data-lucide="alert-circle" class="text-rose-400 opacity-40" size="32"></i>
          </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="glass-card border border-slate-800 p-6 rounded-3xl">
            <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-indigo-500"></div> Outcome Distribution
            </h3>
            <div class="h-128 flex justify-center"><canvas id="pieChart"></canvas></div>
          </div>
          <div class="glass-card border border-slate-800 p-6 rounded-3xl">
            <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-indigo-500"></div> Subject Averages
            </h3>
            <div class="h-64"><canvas id="barChart"></canvas></div>
          </div>
        </div>
      </div>

      <div id="view-students" class="hidden animate-fade-in">
        <div class="glass-card border border-slate-800 rounded-3xl overflow-hidden shadow-2xl">
          <div class="p-6 border-b border-slate-800 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="relative flex-1 max-w-md">
              <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500" size="18"></i>
              <input type="text" id="searchInput" onkeyup="handleSearch()" placeholder="Search students..."
                class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl py-3 pl-12 pr-4 text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 transition-all">
            </div>
            <div class="flex bg-slate-800/80 p-1.5 rounded-2xl border border-slate-700 overflow-x-auto">
              <button onclick="setFilter('All')"
                class="filter-btn active px-5 py-2 rounded-xl text-sm font-semibold bg-indigo-600 text-white">All</button>
              <button onclick="setFilter('Pass')"
                class="filter-btn px-5 py-2 rounded-xl text-sm font-semibold text-slate-500">Pass</button>
              <button onclick="setFilter('Fail')"
                class="filter-btn px-5 py-2 rounded-xl text-sm font-semibold text-slate-500">Fail</button>
              <button onclick="setFilter('ATKT')"
                class="filter-btn px-5 py-2 rounded-xl text-sm font-semibold text-slate-500">ATKT</button>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-slate-800/30 text-slate-500 text-[10px] uppercase font-bold tracking-widest">
                  <th class="px-8 py-5">Full Name</th>
                  <th class="px-4 py-5">Subjects</th>
                  <th class="px-6 py-5">Status</th>
                  <th class="px-6 py-5">Summary</th>
                  <th class="px-8 py-5 text-right">Actions</th>
                </tr>
              </thead>
              <tbody id="studentTableBody" class="divide-y divide-slate-800/50">
                <!-- Data injected via JS -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div id="modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/80 backdrop-blur-md">
    <div
      class="bg-slate-900 border border-slate-800 w-full max-w-2xl rounded-[2.5rem] overflow-hidden shadow-2xl scale-95 transition-transform duration-300"
      id="modalContent">
      <div class="p-8 border-b border-slate-800 flex justify-between items-center bg-slate-900/50">
        <div>
          <h3 id="modal-title" class="text-2xl font-black text-white">Enroll Student</h3>
          <p class="text-sm text-slate-500">Provide details and subject marks</p>
        </div>
        <button onclick="closeModal()"
          class="text-slate-500 hover:text-white p-2 rounded-2xl hover:bg-slate-800 transition-colors"><i
            data-lucide="x"></i></button>
      </div>

      <form id="studentForm" onsubmit="saveStudent(event)" class="p-8">
        <input type="hidden" id="editId">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">First Name</label>
            <input required type="text" id="fname"
              class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none">
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Middle Name</label>
            <input type="text" id="mname"
              class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none">
          </div>
          <div class="space-y-1">
            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Last Name</label>
            <input required type="text" id="lname"
              class="w-full bg-slate-800/50 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none">
          </div>
        </div>

        <div class="mb-4 flex items-center gap-2">
          <div class="h-px bg-slate-800 flex-1"></div>
          <span class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">Marks Inventory (Max
            100)</span>
          <div class="h-px bg-slate-800 flex-1"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-10">
          <div class="space-y-2 text-center">
            <label class="text-[10px] font-bold text-slate-400 uppercase">Maths</label>
            <input required type="number" min="0" max="100" id="m_math"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold">
          </div>
          <div class="space-y-2 text-center">
            <label class="text-[10px] font-bold text-slate-400 uppercase">C++</label>
            <input required type="number" min="0" max="100" id="m_cpp"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold">
          </div>
          <div class="space-y-2 text-center">
            <label class="text-[10px] font-bold text-slate-400 uppercase">Java</label>
            <input required type="number" min="0" max="100" id="m_java"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold">
          </div>
          <div class="space-y-2 text-center">
            <label class="text-[10px] font-bold text-slate-400 uppercase">C</label>
            <input required type="number" min="0" max="100" id="m_c"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold">
          </div>
          <div class="space-y-2 text-center">
            <label class="text-[10px] font-bold text-slate-400 uppercase">HTML</label>
            <input required type="number" min="0" max="100" id="m_html"
              class="w-full bg-slate-800 border border-slate-700 rounded-2xl p-4 text-white focus:ring-2 focus:ring-indigo-600 outline-none text-center font-bold">
          </div>
        </div>

        <div class="flex justify-end gap-4">
          <button type="button" onclick="closeModal()"
            class="px-8 py-4 text-slate-500 hover:text-white font-bold transition-colors">Discard</button>
          <button type="submit"
            class="bg-indigo-600 hover:bg-indigo-700 text-white px-10 py-4 rounded-2xl font-bold shadow-xl shadow-indigo-600/20 transition-all">
            Confirm Enrollment
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast"
    class="fixed bottom-8 right-8 px-6 py-4 rounded-2xl border bg-slate-900 border-slate-800 text-white shadow-2xl translate-x-[200%] transition-transform duration-500 z-[100] flex items-center gap-3">
    <i id="toast-icon" data-lucide="check-circle"></i>
    <span id="toast-msg">Success</span>
  </div>

  <script>
    let students = JSON.parse(localStorage.getItem('rp_students')) || [];
    let currentFilter = 'All';
    let charts = {};

    // Initialization
    window.onload = () => {
      lucide.createIcons();
      updateDashboard();
      renderTable();
    };

    // Navigation
    function switchTab(tab) {
      document.getElementById('view-dashboard').classList.toggle('hidden', tab !== 'dashboard');
      document.getElementById('view-students').classList.toggle('hidden', tab !== 'students');

      document.getElementById('nav-dashboard').classList.toggle('bg-indigo-600', tab === 'dashboard');
      document.getElementById('nav-dashboard').classList.toggle('text-white', tab === 'dashboard');
      document.getElementById('nav-dashboard').classList.toggle('text-slate-400', tab !== 'dashboard');

      document.getElementById('nav-students').classList.toggle('bg-indigo-600', tab === 'students');
      document.getElementById('nav-students').classList.toggle('text-white', tab === 'students');
      document.getElementById('nav-students').classList.toggle('text-slate-400', tab !== 'students');

      document.getElementById('page-title').innerText = tab === 'dashboard' ? 'Academic Insights' : 'Student Database';
      if (tab === 'dashboard') updateDashboard();
    }

    // Calculation Logic
    function calculateResult(marks) {
      const values = Object.values(marks);
      const failCount = values.filter(v => v < 35).length;
      const total = values.reduce((a, b) => a + b, 0);
      const percentage = (total / 500) * 100;

      let status = "Pass";
      if (failCount === 2) status = "ATKT";
      else if (failCount >= 3) status = "Fail";

      return { total, percentage: percentage.toFixed(2), status, failCount };
    }

    // CRUD Operations
    function saveStudent(e) {
      e.preventDefault();
      const editId = document.getElementById('editId').value;
      const marks = {
        Maths: parseInt(document.getElementById('m_math').value),
        Cpp: parseInt(document.getElementById('m_cpp').value),
        Java: parseInt(document.getElementById('m_java').value),
        C_Prog: parseInt(document.getElementById('m_c').value),
        HTML: parseInt(document.getElementById('m_html').value)
      };

      const result = calculateResult(marks);
      const student = {
        id: editId || Date.now().toString(),
        firstName: document.getElementById('fname').value,
        middleName: document.getElementById('mname').value,
        lastName: document.getElementById('lname').value,
        fullName: `${document.getElementById('fname').value} ${document.getElementById('mname').value} ${document.getElementById('lname').value}`.trim(),
        marks,
        ...result
      };

      if (editId) {
        const index = students.findIndex(s => s.id === editId);
        students[index] = student;
        showToast("Record Updated", "check-circle", "emerald");
      } else {
        students.push(student);
        showToast("Student Added", "check-circle", "indigo");
      }

      localStorage.setItem('rp_students', JSON.stringify(students));
      closeModal();
      renderTable();
      updateDashboard();
    }

    function deleteStudent(id) {
      if (confirm("Delete this record permanently?")) {
        students = students.filter(s => s.id !== id);
        localStorage.setItem('rp_students', JSON.stringify(students));
        renderTable();
        updateDashboard();
        showToast("Record Deleted", "trash-2", "rose");
      }
    }

    function editStudent(id) {
      const s = students.find(x => x.id === id);
      document.getElementById('editId').value = s.id;
      document.getElementById('fname').value = s.firstName;
      document.getElementById('mname').value = s.middleName;
      document.getElementById('lname').value = s.lastName;
      document.getElementById('m_math').value = s.marks.Maths;
      document.getElementById('m_cpp').value = s.marks.Cpp;
      document.getElementById('m_java').value = s.marks.Java;
      document.getElementById('m_c').value = s.marks.C_Prog;
      document.getElementById('m_html').value = s.marks.HTML;

      document.getElementById('modal-title').innerText = "Edit Record";
      openModal();
    }

    function renderTable() {
      const body = document.getElementById('studentTableBody');
      const search = document.getElementById('searchInput').value.toLowerCase();

      const filtered = students.filter(s => {
        const matchSearch = s.fullName.toLowerCase().includes(search);
        const matchFilter = currentFilter === 'All' || s.status === currentFilter;
        return matchSearch && matchFilter;
      }).sort((a, b) => b.percentage - a.percentage);

      body.innerHTML = filtered.length ? filtered.map(s => `
                <tr class="hover:bg-slate-800/20 transition-all group border-b border-slate-800/40 last:border-0">
                    <td class="px-8 py-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-indigo-500/10 flex items-center justify-center text-indigo-400 font-bold">${s.firstName[0]}${s.lastName[0]}</div>
                            <div>
                                <div class="font-bold text-white group-hover:text-indigo-400 transition-colors">${s.fullName}</div>
                                <div class="text-[10px] text-slate-500 font-mono">ID: ${s.id.slice(-6)}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-4 py-6">
                        <div class="flex gap-1">
                            ${Object.values(s.marks).map(m => `
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold border ${m < 35 ? 'bg-rose-500/10 text-rose-500 border-rose-500/20' : 'bg-slate-800 text-slate-400 border-slate-700'}">${m}</div>
                            `).join('')}
                        </div>
                    </td>
                    <td class="px-6 py-6">
                        <span class="px-4 py-1.5 rounded-full text-[10px] font-black tracking-widest uppercase flex items-center gap-1.5 w-fit ${s.status === 'Pass' ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : s.status === 'Fail' ? 'bg-rose-500/10 text-rose-500 border border-rose-500/20' : 'bg-amber-500/10 text-amber-500 border border-amber-500/20'}">
                            <div class="w-1.5 h-1.5 rounded-full ${s.status === 'Pass' ? 'bg-emerald-500' : s.status === 'Fail' ? 'bg-rose-500' : 'bg-amber-500'}"></div>
                            ${s.status}
                        </span>
                    </td>
                    <td class="px-6 py-6">
                        <div class="flex flex-col"><span class="text-white font-bold text-lg leading-tight">${s.percentage}%</span><span class="text-[10px] text-slate-500">${s.total} Total</span></div>
                    </td>
                    <td class="px-8 py-6 text-right">
                        <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="downloadPDF('${s.id}')" class="p-2 hover:bg-slate-800 rounded-lg text-slate-400 hover:text-white transition-colors" title="Download Report"><i data-lucide="printer" size="16"></i></button>
                            <button onclick="editStudent('${s.id}')" class="p-2 hover:bg-indigo-500/10 rounded-lg text-indigo-400 transition-colors" title="Edit"><i data-lucide="edit-3" size="16"></i></button>
                            <button onclick="deleteStudent('${s.id}')" class="p-2 hover:bg-rose-500/10 rounded-lg text-rose-400 transition-colors" title="Delete"><i data-lucide="trash-2" size="16"></i></button>
                        </div>
                    </td>
                </tr>
            `).join('') : `<tr><td colspan="5" class="py-32 text-center text-slate-600"><p class="text-lg font-semibold">No records found</p></td></tr>`;

      lucide.createIcons();
    }

    function updateDashboard() {
      const total = students.length;
      const passed = students.filter(s => s.status === 'Pass').length;
      const failed = students.filter(s => s.status === 'Fail').length;
      const atkt = students.filter(s => s.status === 'ATKT').length;

      document.getElementById('stat-total').innerText = total;
      document.getElementById('stat-pass').innerText = total ? Math.round((passed / total) * 100) + '%' : '0%';
      document.getElementById('stat-atkt').innerText = atkt;
      document.getElementById('stat-fail').innerText = failed;

      initCharts(passed, failed, atkt);
    }

    function initCharts(p, f, a) {
      const ctxPie = document.getElementById('pieChart').getContext('2d');
      const ctxBar = document.getElementById('barChart').getContext('2d');

      if (charts.pie) charts.pie.destroy();
      if (charts.bar) charts.bar.destroy();

      charts.pie = new Chart(ctxPie, {
        type: 'doughnut',
        data: {
          labels: ['Pass', 'Fail', 'ATKT'],
          datasets: [{
            data: [p, f, a],
            backgroundColor: ['#10b981', '#ef4444', '#f59e0b'],
            borderWidth: 0,
            hoverOffset: 15
          }]
        },
        options: { cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8' } } } }
      });

      const subjs = ['Maths', 'Cpp', 'Java', 'C_Prog', 'HTML'];
      const avgs = subjs.map(sub => {
        const sum = students.reduce((acc, s) => acc + s.marks[sub], 0);
        return students.length ? (sum / students.length).toFixed(1) : 0;
      });

      charts.bar = new Chart(ctxBar, {
        type: 'bar',
        data: {
          labels: subjs,
          datasets: [{
            label: 'Average Score',
            data: avgs,
            backgroundColor: '#6366f1',
            borderRadius: 10
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: { beginAtZero: true, max: 100, grid: { color: '#1e293b' }, ticks: { color: '#64748b' } },
            x: { grid: { display: false }, ticks: { color: '#64748b' } }
          },
          plugins: { legend: { display: false } }
        }
      });
    }

    function exportToExcel() {
      if (!students.length) return showToast("No data to export", "alert-circle", "amber");
      const data = students.map(s => ({
        "Name": s.fullName,
        "Maths": s.marks.Maths,
        "C++": s.marks.Cpp,
        "Java": s.marks.Java,
        "C": s.marks.C_Prog,
        "HTML": s.marks.HTML,
        "Total": s.total,
        "Percentage": s.percentage + '%',
        "Status": s.status
      }));
      const ws = XLSX.utils.json_to_sheet(data);
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, "Results");
      XLSX.writeFile(wb, "Student_Report.xlsx");
    }

    function importFromExcel(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function (evt) {
        const data = evt.target.result;
        const workbook = XLSX.read(data, { type: 'binary' });
        const sheetName = workbook.SheetNames[0];
        const sheet = workbook.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(sheet);

        rows.forEach(row => {
          const name = row.Name || "Unknown Student";
          const names = name.split(' ');
          const marks = {
            Maths: row.Maths || 0,
            Cpp: row['C++'] || row.Cpp || 0,
            Java: row.Java || 0,
            C_Prog: row.C || row.C_Prog || 0,
            HTML: row.HTML || 0
          };
          const res = calculateResult(marks);
          students.push({
            id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
            firstName: names[0],
            middleName: names.length > 2 ? names[1] : "",
            lastName: names.length > 1 ? names[names.length - 1] : "",
            fullName: name,
            marks, ...res
          });
        });
        localStorage.setItem('rp_students', JSON.stringify(students));
        renderTable();
        updateDashboard();
        showToast(`${rows.length} records imported`, "upload", "emerald");
      };
      reader.readAsBinaryString(file);
    }

    function downloadPDF(id) {
      const s = students.find(x => x.id === id);
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();

      doc.setFillColor(30, 41, 59);
      doc.rect(0, 0, 210, 40, 'F');
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(22);
      doc.text("ACADEMIC REPORT CARD", 105, 25, { align: "center" });

      doc.setTextColor(0, 0, 0);
      doc.setFontSize(12);
      doc.text(`Student: ${s.fullName}`, 20, 55);
      doc.text(`Date: ${new Date().toLocaleDateString('en-GB')}`, 150, 55);

      const tableData = Object.entries(s.marks).map(([k, v]) => [k, v, 100, v >= 35 ? 'PASS' : 'FAIL']);
      doc.autoTable({
        startY: 65,
        head: [['Subject', 'Marks', 'Max', 'Status']],
        body: tableData,
        theme: 'striped',
        headStyles: { fillColor: [99, 102, 241] }
      });

      doc.setFontSize(14);
      doc.text(`Aggregate: ${s.percentage}%`, 20, doc.lastAutoTable.finalY + 15);
      doc.text(`Result: ${s.status}`, 20, doc.lastAutoTable.finalY + 25);

      doc.save(`${s.fullName.replace(/\s/g, '_')}_Result.pdf`);
    }

    function openModal() {
      document.getElementById('modal').classList.remove('hidden');
      document.getElementById('modalContent').classList.remove('scale-95');
      document.getElementById('modalContent').classList.add('scale-100');
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
      document.getElementById('studentForm').reset();
      document.getElementById('editId').value = "";
      document.getElementById('modal-title').innerText = "Enroll Student";
    }

    function handleSearch() {
      renderTable();
    }

    function setFilter(f) {
      currentFilter = f;
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.toggle('bg-indigo-600', btn.innerText === f);
        btn.classList.toggle('text-white', btn.innerText === f);
        btn.classList.toggle('text-slate-500', btn.innerText !== f);
      });
      renderTable();
    }

    function showToast(msg, icon, color) {
      const toast = document.getElementById('toast');
      document.getElementById('toast-msg').innerText = msg;
      document.getElementById('toast-icon').setAttribute('data-lucide', icon);
      toast.className = `fixed bottom-8 right-8 px-6 py-4 rounded-2xl border bg-slate-900 shadow-2xl transition-transform duration-500 z-[100] flex items-center gap-3 border-${color}-500/30 text-${color}-500`;
      lucide.createIcons();
      toast.classList.remove('translate-x-[200%]');
      setTimeout(() => toast.classList.add('translate-x-[200%]'), 3000);
    }
  </script>
</body>

